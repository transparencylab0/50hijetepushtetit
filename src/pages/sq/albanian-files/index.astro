---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { albanianFilesProjects } from "../../../data/albanianFilesProjects";
import type { AlbanianFilesProject } from "../../../data/albanianFilesProjects";
import locationAuditRows from "../../../data/albanianFilesLocationAudit.generated.json";
import {
  albanianFilesLocationResearchById,
  defaultAlbanianFilesLocationResearch
} from "../../../data/albanianFilesLocationResearch";

const statuses = [...new Set(albanianFilesProjects.map((project) => project.status))];
const municipalities = [...new Set(albanianFilesProjects.map((project) => project.municipality))].sort();
const architects = [...new Set(albanianFilesProjects.map((project) => project.architectureCompany))].sort();
const auditRows = locationAuditRows as Array<{
  projectId: string;
  auditStatus: "exact" | "unresolved-book-clue" | "unresolved-city-area-only" | "unresolved-country-only" | "rejected-candidate";
  approximateCoordinates?: { lat: number; lng: number; accuracy: "book-clue-orientation"; note: string };
  bookLocationClues: string[];
  candidateSites: Array<{ name: string; source?: string; url?: string; notes: string; decision: "pending" | "accepted" | "rejected" }>;
  rejectionReason?: string;
  nextResearchLead: string;
  reviewBatch: string;
  lastReviewedAt: string;
}>;
const auditRowsById = new Map(auditRows.map((row) => [row.projectId, row]));
const weakLocationValues = new Set(["", "albania", "needs verification", "unknown", "open lead"]);
const siteCluePattern = /\b(rruga|sheshi|bulevardi|square|stadium|pyramid|marina|waterfront|palace|park|bridge|tower|gate|zone|block|neighborhood|centre|center)\b/i;
const deriveEvidencePages = (project: AlbanianFilesProject) => {
  const pageRange = String(project.bookSource?.page || "").trim();
  return pageRange
    ? [{
        page: pageRange,
        label: `Book source: ${pageRange}`,
        citation: `The Albanian Files: Freedom and Architecture, Lars Müller Publishers, ${pageRange}.`
      }]
    : [];
};
const deriveLocationAudit = (project: AlbanianFilesProject) => {
  const auditRow = auditRowsById.get(project.id);
  if (auditRow) {
    return {
      ...defaultAlbanianFilesLocationResearch,
      locationStatus: auditRow.approximateCoordinates ? "approximate" : defaultAlbanianFilesLocationResearch.locationStatus,
      auditStatus: auditRow.auditStatus,
      approximateCoordinates: auditRow.approximateCoordinates,
      bookLocationClues: auditRow.bookLocationClues,
      candidateSites: auditRow.candidateSites,
      rejectionReason: auditRow.rejectionReason,
      locationEvidenceNotes: auditRow.approximateCoordinates
        ? `${auditRow.nextResearchLead} Approximate marker is for orientation only and is not a verified site.`
        : auditRow.nextResearchLead,
      reviewerNotes: "Generated by the full-audit workflow from book/OCR page evidence. Promote only after public confirmation.",
      reviewBatch: auditRow.reviewBatch,
      lastReviewedAt: auditRow.lastReviewedAt
    };
  }
  const location = String(project.location || "").trim();
  const municipality = String(project.municipality || "").trim();
  const combined = `${project.name} ${location} ${municipality}`;
  const locationKey = location.toLowerCase();
  const auditStatus = weakLocationValues.has(locationKey)
    ? "unresolved-country-only"
    : siteCluePattern.test(combined)
      ? "unresolved-book-clue"
      : "unresolved-city-area-only";
  const clueSummary =
    auditStatus === "unresolved-book-clue"
      ? "Book/OCR has a possible site clue, but no independent public source has confirmed the exact site yet."
      : auditStatus === "unresolved-city-area-only"
        ? "Book/OCR appears to give city or area only. Exact site needs page-image and public-source review."
        : "Book/OCR gives only Albania or unclear location. Exact site needs manual page-image review.";
  return {
    ...defaultAlbanianFilesLocationResearch,
    auditStatus,
    bookLocationClues: [
      `${project.bookSource?.page || "PDF pages pending"} in the ${project.architectureCompany} section.`,
      `Book/OCR project name: ${project.name}.`,
      location && !weakLocationValues.has(locationKey) ? `Book/OCR location field: ${location}.` : "Book/OCR location field is country-level, unclear, or missing.",
      municipality && municipality !== location ? `Book/OCR municipality field: ${municipality}.` : ""
    ].filter(Boolean),
    candidateSites: [
      {
        name: `${project.name} public location search`,
        source: "Manual verification candidate",
        url: `https://www.google.com/search?q=${encodeURIComponent(`${project.name} ${location} ${project.architectureCompany} Albania`)}`,
        notes: "Use only to confirm a book-derived clue; do not promote without matching public evidence.",
        decision: "pending"
      }
    ],
    locationEvidenceNotes: clueSummary,
    reviewerNotes: "Generated by the full-audit workflow. Promote to an exact pin only after book clue plus independent public confirmation.",
    reviewBatch: "full-audit-2026-06-26"
  };
};
const enrichedProjects = albanianFilesProjects.map((project) => ({
  ...project,
  locationResearch: albanianFilesLocationResearchById[project.id] ?? deriveLocationAudit(project),
  evidencePages: deriveEvidencePages(project)
}));
const exactLocationCount = enrichedProjects.filter((project) => project.locationResearch.locationStatus === "exact").length;
const approximateLocationCount = enrichedProjects.filter((project) => project.locationResearch.locationStatus === "approximate").length;
const unresolvedLocationCount = enrichedProjects.length - exactLocationCount - approximateLocationCount;
const statusLabels = {
  built: "Built",
  proposed: "Planned",
  competition: "Competition",
  cancelled: "Cancelled",
  unknown: "Unknown"
};
const locationStatusLabels = {
  exact: "Exact site verified",
  approximate: "Approximate / needs review",
  unresolved: "No verified site yet"
};
const pageData = JSON.stringify(enrichedProjects).replace(/</g, "\\u003c");
---

<BaseLayout
  title="Albanian Files Map | 50hijetepushtetit"
  description="Interactive evidence map and relationship graph for projects from The Albanian Files: Freedom and Architecture."
  canonicalPath="/sq/albanian-files/"
  appShell
>
  <section class="af-map-app af-claude" data-albanian-files-workspace>
    <div id="albanian-files-map" class="af-map-canvas" aria-label="Interactive Albania project map"></div>

    <header class="af-command af-command-desktop" aria-label="Map command bar">
      <div class="af-brand-cell">
        <span class="af-pulse" aria-hidden="true"></span>
        <strong>Albanian Files</strong>
      </div>

      <form class="af-controls" data-map-filters>
        <label class="af-search">
          <span class="sr-only">Search</span>
          <input type="search" name="q" placeholder="Search project, architect, city..." autocomplete="off" />
        </label>
        <label>
          <span class="sr-only">Status</span>
          <select name="status">
            <option value="">All statuses</option>
            {statuses.map((status) => <option value={status}>{statusLabels[status]}</option>)}
          </select>
        </label>
        <label>
          <span class="sr-only">City</span>
          <select name="municipality">
            <option value="">All cities</option>
            {municipalities.map((municipality) => <option value={municipality}>{municipality}</option>)}
          </select>
        </label>
        <label>
          <span class="sr-only">Architect</span>
          <select name="architect">
            <option value="">All architects</option>
            {architects.map((architect) => <option value={architect}>{architect}</option>)}
          </select>
        </label>
        <label>
          <span class="sr-only">Location verification</span>
          <select name="locationStatus">
            <option value="">All locations</option>
            {Object.entries(locationStatusLabels).map(([value, label]) => <option value={value}>{label}</option>)}
          </select>
        </label>
      </form>

      <p class="af-count" data-map-result-line>{albanianFilesProjects.length}/439</p>
      <button class="af-reset-button" type="button" data-clear-filters>Reset</button>
    </header>

    <header class="af-mobile-command" aria-label="Mobile map command bar">
      <div class="af-brand-cell">
        <span class="af-pulse" aria-hidden="true"></span>
        <strong>AF</strong>
      </div>
      <label class="af-mobile-search">
        <span class="sr-only">Search</span>
        <input type="search" name="mobile-q" placeholder="Search..." autocomplete="off" data-mobile-search />
      </label>
      <button class="af-filter-toggle" type="button" data-toggle-mobile-filters>Filters</button>
      <p class="af-count" data-mobile-result-line>{albanianFilesProjects.length}</p>
    </header>

    <section class="af-mobile-filters" data-mobile-filters hidden>
      <button class="af-filter-backdrop" type="button" data-toggle-mobile-filters aria-label="Close filters"></button>
      <div class="af-filter-sheet">
        <span class="af-sheet-grip" aria-hidden="true"></span>
        <h2>Filters</h2>
        <form data-mobile-map-filters>
          <label>
            <span>Status</span>
            <select name="status">
              <option value="">All statuses</option>
              {statuses.map((status) => <option value={status}>{statusLabels[status]}</option>)}
            </select>
          </label>
          <label>
            <span>City</span>
            <select name="municipality">
              <option value="">All cities</option>
              {municipalities.map((municipality) => <option value={municipality}>{municipality}</option>)}
            </select>
          </label>
          <label>
            <span>Architect / firm</span>
            <select name="architect">
              <option value="">All architects</option>
              {architects.map((architect) => <option value={architect}>{architect}</option>)}
            </select>
          </label>
          <label>
            <span>Location verification</span>
            <select name="locationStatus">
              <option value="">All locations</option>
              {Object.entries(locationStatusLabels).map(([value, label]) => <option value={value}>{label}</option>)}
            </select>
          </label>
          <div class="af-filter-actions">
            <button type="button" data-clear-filters>Reset</button>
            <button type="button" data-toggle-mobile-filters>Apply</button>
          </div>
        </form>
      </div>
    </section>

    <aside class="af-status-legend af-project-legend" aria-label="Project marker legend">
      <p>Project map</p>
      <span><i data-project-marker="exact"></i>Solid: exact verified site</span>
      <span><i data-project-marker="approximate"></i>Hollow: approximate book-clue area</span>
      <span><i data-project-marker="unresolved"></i>List: location still unresolved</span>
      <small>{exactLocationCount} exact / {approximateLocationCount} approximate / {unresolvedLocationCount} unresolved</small>
    </aside>

    <aside class="af-ocr-warning">
      <span aria-hidden="true">⚠</span>
      All 439 records are OCR-derived. Pins show verified or approximate locations only; project details still need source review.
    </aside>

    <aside class="af-location-summary" aria-label="Location verification summary">
      <p>Location verification</p>
      <strong data-location-count-line>{exactLocationCount} exact / {approximateLocationCount} approximate / {unresolvedLocationCount} unresolved</strong>
      <span>Approximate markers are not site coordinates.</span>
    </aside>

    <aside class="af-location-leads" data-location-leads aria-live="polite"></aside>

    <aside class="af-dossier-card" data-dossier-panel aria-live="polite" hidden></aside>

    <section class="af-file-modal" data-file-modal hidden>
      <button class="af-modal-backdrop" type="button" data-close-file aria-label="Close file"></button>
      <article class="af-file-card">
        <div class="af-dark-head">
          <p>Case File · 50 Hijet e Pushtetit / 50 Shades of Power</p>
          <h2 data-file-title></h2>
          <div data-file-chips></div>
          <button class="af-dark-close" type="button" data-close-file aria-label="Close file">×</button>
        </div>
        <div class="af-evidence-alert">
          <span aria-hidden="true">⚠</span>
          All information is OCR-derived from a scanned document. It has not been independently verified and should not be treated as established fact.
        </div>
        <div class="af-file-body" data-file-body></div>
      </article>
    </section>

    <section class="af-graph-overlay" data-mindmap-panel hidden>
      <div class="af-graph-head">
        <div>
          <p>Relationship Map</p>
          <h2 data-mindmap-title>Project network</h2>
          <span>Drag nodes to rearrange · click an entity to highlight pins</span>
        </div>
        <button class="af-dark-close" type="button" data-close-mindmap aria-label="Close mind map">×</button>
      </div>
      <div class="af-graph-legend">
        <p>Project relations</p>
        <span><i data-node="normal-actor"></i>Architect / actor</span>
        <span><i data-node="project"></i>Project</span>
      </div>
      <svg id="mindmap-svg" data-mindmap-stage></svg>
    </section>

    <section class="af-graph-overlay" data-network-panel hidden>
      <div class="af-graph-head">
        <div>
          <p data-network-kicker>Project Network · 439 projects</p>
          <h2 data-network-title>Project Relationships</h2>
          <span>Node size = number of projects · click an entity to highlight pins</span>
        </div>
        <button class="af-dark-close" type="button" data-close-network aria-label="Close network">×</button>
      </div>
      <div class="af-graph-legend">
        <p>Project relations</p>
        <span><i data-node="normal-actor"></i>Architect / actor</span>
        <span><i data-node="project-dot"></i>Project</span>
      </div>
      <svg id="network-svg" data-network-stage></svg>
    </section>

    <div class="af-map-fallback" data-map-fallback hidden>
      Map library unavailable. The local Albania boundary file remains available at
      <a href="/data/albania-boundary.geojson">/data/albania-boundary.geojson</a>.
    </div>
  </section>

  <script is:inline type="application/json" id="albanian-files-projects" set:html={pageData} />
  <link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />
  <link rel="stylesheet" href="/vendor/leaflet.markercluster/MarkerCluster.css" />
  <script is:inline src="/vendor/leaflet/leaflet.js"></script>
  <script is:inline src="/vendor/leaflet.markercluster/leaflet.markercluster.js"></script>
  <script is:inline src="/vendor/d3/d3.min.js"></script>
  <script is:inline src="/scripts/albanian-files-map.js"></script>
</BaseLayout>
