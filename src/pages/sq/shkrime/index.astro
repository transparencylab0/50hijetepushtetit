---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles"))
  .filter((item) => item.data.type !== "profil")
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const typeLabels = {
  skandal: "Skandal",
  profil: "Profil",
  analize: "Analize",
  perditesim: "Perditesim",
  opinion: "Opinion"
};

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("sq-AL", {
    day: "2-digit",
    month: "long",
    year: "numeric"
  }).format(date);
---

<BaseLayout title="Shkrime | 50hijetepushtetit" description="Artikuj, analiza dhe perditesime te bazuara ne burime publike.">
  <section class="section article-index">
    <div class="section-heading wide">
      <p class="eyebrow">Shkrime</p>
      <h1>Artikuj te lexueshem, me burime.</h1>
      <p class="lead">
        Skandale, analiza dhe perditesime te shkruara si faqe publike:
        cfare dihet, cfare mungon dhe ku jane dokumentet.
      </p>
    </div>

    <div class="article-list">
      {articles.map((item) => (
        <article class="article-row">
          <div class="article-row-meta">
            <span>{typeLabels[item.data.type]}</span>
            <time datetime={item.data.publishedAt.toISOString()}>{formatDate(item.data.publishedAt)}</time>
            <small>{item.data.author}</small>
          </div>
          <div class="article-row-copy">
            <h2><a href={`/sq/shkrime/${item.id}/`}>{item.data.title}</a></h2>
            <p>{item.data.summary}</p>
            <div class="tag-row">
              {item.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </div>
          <a class="read-link" href={`/sq/shkrime/${item.id}/`}>Lexo</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
