---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles-en"))
  .filter((item) => item.data.type !== "profil")
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const typeLabels = {
  skandal: "Scandal",
  profil: "Profile",
  analize: "Analysis",
  perditesim: "Update",
  opinion: "Opinion"
};

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    day: "2-digit",
    month: "long",
    year: "numeric"
  }).format(date);
---

<BaseLayout lang="en" title="Articles | 50 Shades of Power" description="Articles, analysis and updates based on public sources.">
  <section class="section article-index">
    <div class="section-heading wide">
      <p class="eyebrow">Articles</p>
      <h1>Readable articles, with sources.</h1>
      <p class="lead">
        Scandals, analysis and updates written as public pages:
        what is known, what is missing and where the documents are.
      </p>
    </div>

    <div class="article-list">
      {articles.map((item) => (
        <article class="article-row">
          <div class="article-row-meta">
            <span>{typeLabels[item.data.type]}</span>
            <time datetime={item.data.publishedAt.toISOString()}>{formatDate(item.data.publishedAt)}</time>
            <small>{item.data.author}</small>
          </div>
          <div class="article-row-copy">
            <h2><a href={`/en/articles/${item.id}/`}>{item.data.title}</a></h2>
            <p>{item.data.summary}</p>
            <div class="tag-row">
              {item.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </div>
          <a class="read-link" href={`/en/articles/${item.id}/`}>Read</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
