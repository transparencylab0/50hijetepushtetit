---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = (await getCollection("articles-en")).filter((item) => item.data.type !== "profil");
  return articles.map((item) => ({
    params: { slug: item.id },
    props: { item }
  }));
}

const { item } = Astro.props;
const keyFacts = item.data.keyFacts ?? [];
const { Content } = await render(item);
const cases = await getCollection("cases-en");
const albanianArticles = (await getCollection("articles")).filter((article) => article.data.type !== "profil");
const hasAlbanianVersion = albanianArticles.some((article) => article.id === item.id);
const caseBySlug = new Map(cases.map((caseItem) => [caseItem.id, caseItem]));
const relatedCases = item.data.relatedCases.flatMap((slug) => {
  const caseItem = caseBySlug.get(slug);
  return caseItem ? [caseItem] : [];
});

const typeLabels = {
  skandal: "Scandal",
  profil: "Profile",
  analize: "Analysis",
  perditesim: "Update",
  opinion: "Opinion"
};

const replySubject = encodeURIComponent(`Right of reply: ${item.data.title}`);
const replyBody = encodeURIComponent(
  `Article: /en/articles/${item.id}/\n\nWrite your reply, correction, or source note here. Attach documents or source links if possible.`
);
const replyMailto = `mailto:thetourist1@proton.me?subject=${replySubject}&body=${replyBody}`;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    day: "2-digit",
    month: "long",
    year: "numeric"
  }).format(date);
---

<BaseLayout lang="en" title={`${item.data.title} | 50 Shades of Power`} description={item.data.summary}>
  <article class="article-page">
    <header class="article-hero">
      <p class="eyebrow">{typeLabels[item.data.type]}</p>
      <h1>{item.data.title}</h1>
      <p class="lead">{item.data.summary}</p>
      <div class="article-meta-line">
        <time datetime={item.data.publishedAt.toISOString()}>{formatDate(item.data.publishedAt)}</time>
        <span class="article-author">By {item.data.author}</span>
        {item.data.updatedAt && <span>Updated: {formatDate(item.data.updatedAt)}</span>}
        <span>{item.data.sources.length} sources</span>
      </div>
      <div class="tag-row">
        {item.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
      {keyFacts.length > 0 && (
        <div class="article-facts" aria-label="Key figures">
          {keyFacts.map((fact) => (
            <div class="article-fact">
              <strong>{fact.value}</strong>
              <span>{fact.label}</span>
            </div>
          ))}
        </div>
      )}
      {item.data.disclaimer && <p class="article-disclaimer">{item.data.disclaimer}</p>}
      {item.data.image && (
        <figure class={`article-image${item.data.image.layout === "portrait" ? " portrait" : ""}`}>
          <img src={item.data.image.src} alt={item.data.image.alt} loading="lazy" decoding="async" />
          <figcaption>
            {item.data.image.sourceUrl ? (
              <a href={item.data.image.sourceUrl}>{item.data.image.credit}</a>
            ) : (
              <span>{item.data.image.credit}</span>
            )}
            {item.data.image.license && <span>{item.data.image.license}</span>}
          </figcaption>
        </figure>
      )}
      {hasAlbanianVersion && <p class="legal-note"><a href={`/sq/shkrime/${item.id}/`}>Open Albanian version</a></p>}
    </header>

    <section class="article-body prose">
      <Content />
    </section>

    {item.data.sources.length > 0 && (
      <section class="article-support">
        <h2>Sources</h2>
        <div class="source-table">
          {item.data.sources.map((source) => (
            <article>
              <div>
                <strong>{source.title}</strong>
                <span>{source.publisher}{source.date ? ` · ${source.date}` : ""}</span>
                {source.note && <small>{source.note}</small>}
              </div>
              <div class="source-actions">
                <a href={source.url}>{source.linkLabel ?? "Source"}</a>
                {source.archiveUrl && <a href={source.archiveUrl}>Archive</a>}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {item.data.rightOfReply && (
      <section class="article-support reply-box">
        <h2>Right of reply</h2>
        <p>
          Anyone mentioned in this article can reply, correct details, or send documents. Replies are reviewed
          manually and may be published as updates when relevant.
        </p>
        <a class="button" href={replyMailto}>Email a reply</a>
      </section>
    )}

    {relatedCases.length > 0 && (
      <section class="article-support">
        <h2>Related files</h2>
        <div class="related-case-list">
          {relatedCases.map((caseItem) => (
            <a href={`/en/files/${caseItem.id}/`}>
              <strong>{caseItem.data.title}</strong>
              <span>{caseItem.data.summary}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
