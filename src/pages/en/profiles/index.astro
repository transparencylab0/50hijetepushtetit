---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const profiles = (await getCollection("articles-en"))
  .filter((item) => item.data.type === "profil")
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    day: "2-digit",
    month: "long",
    year: "numeric"
  }).format(date);
---

<BaseLayout lang="en" title="Profiles | 50 Shades of Power" description="Public profiles of political and institutional figures, with sources and open questions.">
  <section class="section article-index">
    <div class="section-heading wide">
      <p class="eyebrow">Profiles</p>
      <h1>Public figures, read through documents.</h1>
      <p class="lead">
        Short profiles for political and institutional roles: what power they held,
        which events connect to their mandate and which documents should be followed.
      </p>
    </div>

    <div class="article-list">
      {profiles.map((item) => (
        <article class="article-row profile-row">
          <div class="article-row-meta">
            <span>Profile</span>
            <time datetime={item.data.publishedAt.toISOString()}>{formatDate(item.data.publishedAt)}</time>
          </div>
          {item.data.image && (
            <a class="profile-thumb" href={`/en/profiles/${item.id}/`} aria-label={`Open ${item.data.title}`}>
              <img src={item.data.image.src} alt={item.data.image.alt} loading="lazy" decoding="async" />
            </a>
          )}
          <div class="article-row-copy">
            <h2><a href={`/en/profiles/${item.id}/`}>{item.data.title}</a></h2>
            <p>{item.data.summary}</p>
            <div class="tag-row">
              {item.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </div>
          <a class="read-link" href={`/en/profiles/${item.id}/`}>Read</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
